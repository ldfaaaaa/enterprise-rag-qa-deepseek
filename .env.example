# DeepSeek API Key（必填）
# 前往 https://platform.deepseek.com/ 获取
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 向量化模型配置
# 默认使用 HuggingFace 本地模型（免费，推荐，无需 Key）
# 模型：BAAI/bge-small-zh-v1.5，首次运行会自动下载（约 100MB）

# 如果你希望使用 OpenAI Embeddings 替代本地模型，取消注释以下两行：
# OPENAI_API_KEY=your_openai_api_key_here
# USE_OPENAI_EMBEDDINGS=true
